{
  "expo": {
    "name": "Daytri",
    "slug": "daytri",
    "version": "1.0.0",
    "icon": "./assets/daytri-icon.png",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "daytri",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/daytri-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F1EB"
    },
    "ios": {
      "bundleIdentifier": "com.samuel.daytri",
      "supportsTablet": true,
      "icon": "./assets/daytri-icon.png"
    },
    "android": {
      "package": "com.samuel.daytri",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/daytri-icon.png",
        "backgroundColor": "#F5F1EB"
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#F6F1EA",
      "barStyle": "dark-content",
      "translucent": false
    },
    "androidNavigationBar": {
      "backgroundColor": "#FCF8F1",
      "barStyle": "dark-content"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#A68F72"
        }
      ],
      "expo-asset",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "4025a8f7-6218-4692-a64c-9015d9ca5903"
      }
    }
  }
}
